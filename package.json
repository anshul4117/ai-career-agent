{
  "name": "ai-career-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade AI Career Agent platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@ai-career-agent/web",
    "build": "npm run build --workspace=@ai-career-agent/web",
    "lint": "npm run lint --workspace=@ai-career-agent/web",
    "type-check": "npm run type-check --workspace=@ai-career-agent/web",
    "test": "echo \"Test scripts to be configured\"",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { try { require('child_process').execSync('husky', { stdio: 'inherit' }) } catch (e) {} }\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.9.5"
  }
}
